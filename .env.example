# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID администраторов (через запятую, без пробелов)
ADMINS=123456789,987654321

# Путь к файлу SQLite базы данных (опционально, по умолчанию data/database.db)
DB_PATH=data/database.db

# API ключ для Gemini (обязательно для анализа фото еды)
# Получить можно на https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
